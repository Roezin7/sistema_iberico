# Conexión a Postgres (Render). El usuario debe ROTAR esta contraseña antes de producción.
DATABASE_URL="postgresql://usuario:password@host:5432/dbname?sslmode=require"

# Secreto para firmar JWT (cámbialo por un valor largo y aleatorio)
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# Puerto del servidor (Render inyecta PORT automáticamente)
PORT=3000

# API de Anthropic — para Silvia (coach) y el borrador de conteo IA (Fase 7). Opcional.
ANTHROPIC_API_KEY=""

# Entorno
NODE_ENV="development"

# CORS: orígenes permitidos separados por coma. Vacío = solo mismo origen (lo normal
# en el despliegue de un solo servicio). Ej: "https://app.iberico.com,https://admin.iberico.com"
ALLOWED_ORIGINS=""
